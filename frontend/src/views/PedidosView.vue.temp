              <p>Modal aberto: {{ showItensModal }}</p>
              <p>Pedido selecionado: {{ selectedPedido?.id_pedido }}</p>
              <p>Itens carregados: {{ itens?.length || 0 }}</p>
            </div>
          </div>

          <div v-else>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-2 text-left font-medium text-gray-700">Produto</th>
                    <th class="px-4 py-2 text-left font-medium text-gray-700">Referência</th>
                    <th class="px-4 py-2 text-center font-medium text-gray-700">Tamanhos</th>
                    <th class="px-4 py-2 text-right font-medium text-gray-700">Qtd Total</th>
                    <th class="px-4 py-2 text-right font-medium text-gray-700">Valor</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <tr v-for="item in itens" :key="item.id_item_pedido" class="hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium text-gray-900">
                      {{ item.produto?.produto || item.produto || 'Produto não informado' }}
                    </td>
                    <td class="px-4 py-3 text-gray-600">
                      {{ item.referencia || item.produto?.referencia || '-' }}
                    </td>
                    <td class="px-4 py-3">
                      <div class="flex flex-wrap gap-1">
                        <span v-if="item.tam_pp" class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-100 text-blue-800">PP:{{ item.tam_pp }}</span>
                        <span v-if="item.tam_p" class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-100 text-blue-800">P:{{ item.tam_p }}</span>
                        <span v-if="item.tam_m" class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-100 text-blue-800">M:{{ item.tam_m }}</span>
                        <span v-if="item.tam_g" class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-100 text-blue-800">G:{{ item.tam_g }}</span>
                        <span v-if="item.tam_u" class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-100 text-blue-800">U:{{ item.tam_u }}</span>
                        <span v-if="item.tam_rn" class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-100 text-blue-800">RN:{{ item.tam_rn }}</span>
                        <span v-if="item.ida_1" class="inline-flex items-center px-2 py-1 rounded text-xs bg-pink-100 text-pink-800">1:{{ item.ida_1 }}</span>
                        <span v-if="item.ida_2" class="inline-flex items-center px-2 py-1 rounded text-xs bg-pink-100 text-pink-800">2:{{ item.ida_2 }}</span>
                        <span v-if="item.ida_3" class="inline-flex items-center px-2 py-1 rounded text-xs bg-pink-100 text-pink-800">3:{{ item.ida_3 }}</span>
                        <span v-if="item.ida_4" class="inline-flex items-center px-2 py-1 rounded text-xs bg-pink-100 text-pink-800">4:{{ item.ida_4 }}</span>
                        <span v-if="item.ida_6" class="inline-flex items-center px-2 py-1 rounded text-xs bg-pink-100 text-pink-800">6:{{ item.ida_6 }}</span>
                        <span v-if="item.ida_8" class="inline-flex items-center px-2 py-1 rounded text-xs bg-pink-100 text-pink-800">8:{{ item.ida_8 }}</span>
                        <span v-if="item.ida_10" class="inline-flex items-center px-2 py-1 rounded text-xs bg-pink-100 text-pink-800">10:{{ item.ida_10 }}</span>
                        <span v-if="item.ida_12" class="inline-flex items-center px-2 py-1 rounded text-xs bg-pink-100 text-pink-800">12:{{ item.ida_12 }}</span>
                        <span v-if="item.lisa" class="inline-flex items-center px-2 py-1 rounded text-xs bg-purple-100 text-purple-800">Lisa:{{ item.lisa }}</span>
                      </div>
                    </td>
                    <td class="px-4 py-3 text-right font-medium">
                      {{ item.tam_pp + item.tam_p + item.tam_m + item.tam_g + item.tam_u + item.tam_rn + item.ida_1 + item.ida_2 + item.ida_3 + item.ida_4 + item.ida_6 + item.ida_8 + item.ida_10 + item.ida_12 + item.lisa }}
                    </td>
                    <td class="px-4 py-3 text-right font-semibold text-green-600">
                      R$ {{ formatMoney(item.total_item) }}
                    </td>
                  </tr>
                </tbody>
                <tfoot class="bg-gray-50">
                  <tr>
                    <td colspan="3" class="px-4 py-3 text-right font-semibold">Total do Pedido:</td>
                    <td class="px-4 py-3 text-right font-bold text-lg text-blue-600">
                      {{ itens.reduce((total, item) => total + (item.tam_pp + item.tam_p + item.tam_m + item.tam_g + item.tam_u + item.tam_rn + item.ida_1 + item.ida_2 + item.ida_3 + item.ida_4 + item.ida_6 + item.ida_8 + item.ida_10 + item.ida_12 + item.lisa), 0) }} unidades
                    </td>
                    <td class="px-4 py-3 text-right font-bold text-lg text-green-600">
                      R$ {{ formatMoney(itens.reduce((total, item) => total + parseFloat(item.total_item || 0), 0)) }}
                    </td>
                  </tr>
                </tfoot>
              </table>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 px-6 py-4 flex justify-between items-center">
          <div class="text-sm text-gray-600 flex items-center gap-4">
            <span><span class="font-medium">{{ itens?.length || 0 }}</span> produto(s) encontrado(s)</span>
            <span v-if="selectedPedido" class="text-gray-500">
              Pedido #{{ selectedPedido.id_pedido }} •
              <span :class="selectedPedido.status === 'concluido' ? 'text-green-600' : selectedPedido.status === 'cancelado' ? 'text-red-600' : 'text-yellow-600'">
                {{ selectedPedido.status || 'pendente' }}
              </span>
            </span>
          </div>
          <button @click="showItensModal = false" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium">
            Fechar
          </button>
        </div>
      </div>
    </div>

    <!-- Modal Cálculo Detalhado (Simplificado) -->
    <div v-if="showCalculoModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-[100] p-4">
      <div class="bg-white rounded-lg shadow-xl w-full max-w-md max-h-[60vh] overflow-hidden">
        <div class="bg-green-600 text-white px-6 py-4">
          <div class="flex justify-between items-center">
            <h2 class="text-lg font-semibold">Cálculo Detalhado</h2>
            <button @click="showCalculoModal = false" class="text-white hover:bg-white hover:bg-opacity-20 rounded-full p-1 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
        </div>

        <div class="p-6">
          <div v-if="calcLoading" class="text-center py-8">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-green-600 mx-auto mb-4"></div>
            <p class="text-gray-600">Carregando dados...</p>
          </div>
          <div v-else class="text-center py-8">
            <svg class="w-12 h-12 mx-auto text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
            </svg>
            <p class="text-gray-500">Funcionalidade em desenvolvimento</p>
            <p class="text-gray-400 text-sm mt-1">Em breve disponível</p>
          </div>
        </div>

        <div class="bg-gray-50 px-6 py-4 flex justify-end">
          <button @click="showCalculoModal = false" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors font-medium">
            Fechar
          </button>
        </div>
      </div>
    </div>
